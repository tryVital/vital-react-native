{
  "name": "example",
  "version": "0.0.1",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "reset": "expo start -c",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/native-stack": "^6.9.17",
    "@tryvital/vital-core-react-native": "file:../packages/vital-core-react-native",
    "@tryvital/vital-devices-react-native": "file:../packages/vital-devices-react-native",
    "@tryvital/vital-health-react-native": "file:../packages/vital-health-react-native",
    "@tryvital/vital-node": "^3.1.544",
    "events": "^1.1.1",
    "expo": "^54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "native-base": "^3.4.28",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-dialog": "^9.3.0",
    "react-native-permissions": "^3.6.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^1.3.0",
    "react-native-webview": "13.15.0",
    "readable-stream": "^1.0.33",
    "stream-browserify": "^1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-typescript": "7.12.7",
    "@babel/runtime": "^7.25.0",
    "@tsconfig/react-native": "^2.0.2",
    "@types/jest": "^29.5.13",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^5.37.0",
    "@typescript-eslint/parser": "^5.37.0",
    "babel-jest": "^26.6.3",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^7.32.0",
    "jest": "^29.2.1",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@tryvital/vital-core-react-native",
          "@tryvital/vital-devices-react-native",
          "@tryvital/vital-health-react-native"
        ]
      },
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "engines": {
    "node": ">=20.19.4"
  }
}
